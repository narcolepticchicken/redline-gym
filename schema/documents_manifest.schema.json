{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redline-gym.local/schema/documents_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["documents"],
  "properties": {
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["doc_id", "title", "type", "path", "sha256", "is_distractor"],
        "properties": {
          "doc_id": {
            "type": "string",
            "pattern": "^DOC-[0-9]{2}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["msa", "sow", "nda", "addendum", "exhibit", "employment_agreement", "stockholders_agreement"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "is_distractor": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
