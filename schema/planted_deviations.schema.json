{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redline-gym.local/schema/planted_deviations.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["deviations", "distractors", "missing_info", "generation_log"],
  "properties": {
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "deviation_id",
          "rule_id",
          "doc_id",
          "clause_anchor",
          "original_text",
          "mutated_text",
          "mechanism",
          "severity",
          "expected_action"
        ],
        "properties": {
          "deviation_id": {
            "type": "string",
            "pattern": "^D-[0-9]{3}$"
          },
          "rule_id": {
            "type": "string",
            "pattern": "^R-[0-9]{3}$"
          },
          "doc_id": {
            "type": "string",
            "pattern": "^DOC-[0-9]{2}$"
          },
          "clause_anchor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["section", "span"],
            "properties": {
              "section": {"type": "string", "minLength": 1},
              "span": {"type": "string", "minLength": 1}
            }
          },
          "original_text": {"type": "string", "minLength": 1},
          "mutated_text": {"type": "string", "minLength": 1},
          "mechanism": {
            "type": "string",
            "enum": [
              "direct_term_swap",
              "cross_ref_override",
              "defined_term_shift",
              "omission",
              "off_playbook_addition",
              "cross_doc_override"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "expected_action": {
            "type": "string",
            "enum": ["redline_with_fallback", "flag_only", "escalate"]
          }
        }
      }
    },
    "distractors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["distractor_id", "doc_id", "span", "why_benign"],
        "properties": {
          "distractor_id": {
            "type": "string",
            "pattern": "^X-[0-9]{3}$"
          },
          "doc_id": {
            "type": "string",
            "pattern": "^DOC-[0-9]{2}$"
          },
          "span": {"type": "string", "minLength": 1},
          "why_benign": {"type": "string", "minLength": 1}
        }
      }
    },
    "missing_info": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["missing_info_id", "topic", "absent_terms", "expected_action"],
        "properties": {
          "missing_info_id": {
            "type": "string",
            "pattern": "^M-[0-9]{3}$"
          },
          "topic": {"type": "string", "minLength": 1},
          "absent_terms": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "expected_action": {
            "const": "escalate"
          }
        }
      }
    },
    "generation_log": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
